# Maintainer: Ian McMurray <ian.mcmurray@gmail.com>
#
# Source-build pacman package for spanpaper. Pulls the tagged source
# tarball from GitHub, compiles, and produces a .pkg.tar.zst you can
# install with `pacman -U`.
#
# Build + install on this machine:
#   cd contrib && makepkg -si
#
# Build only (just produce the .pkg.tar.zst for copying elsewhere):
#   cd contrib && makepkg
#
# Cutting a new version: bump pkgver, then run `updpkgsums` to refresh
# the sha256 against the live GitHub tarball.

pkgname=spanpaper
pkgver=0.3.1
pkgrel=1
pkgdesc="Wayland wallpaper daemon + tray applet — single image or video spanned across stacked monitors"
arch=('x86_64')
url="https://github.com/imcmurray/spanpaper"
license=('MIT')
# mpvpaper + swaybg drive the wallpaper rendering. gtk4 and
# gtk4-layer-shell are linked by the bundled tray applet; the daemon
# itself doesn't need them at runtime, but we always ship both
# binaries since 0.3.0 so the deps are unconditional.
depends=('mpvpaper' 'swaybg' 'gtk4' 'gtk4-layer-shell')
makedepends=('cargo')
options=('!lto')   # Cargo.toml already sets `lto = "thin"`; let it own that knob.
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('1fdf9bd1ba43e070709a04fea5057d4edfcb4fa3ffb79f5968d6bacece855215')

prepare() {
    cd "$pkgname-$pkgver"
    export CARGO_HOME="$srcdir/cargo-home"
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    cd "$pkgname-$pkgver"
    export CARGO_HOME="$srcdir/cargo-home"
    export CARGO_TARGET_DIR="$srcdir/target"
    # --features tray pulls in ksni/tokio/gtk4/gtk4-layer-shell so the
    # spanpaper-tray binary is produced alongside the daemon.
    cargo build --frozen --release --features tray
}

package() {
    cd "$pkgname-$pkgver"

    install -Dm755 "$srcdir/target/release/spanpaper" \
        "$pkgdir/usr/bin/spanpaper"
    install -Dm755 "$srcdir/target/release/spanpaper-tray" \
        "$pkgdir/usr/bin/spanpaper-tray"

    # contrib templates have an @SPANPAPER_BIN@ / @SPANPAPER_TRAY_BIN@
    # placeholder that setup.sh substitutes for ad-hoc installs; for
    # the packaged install we hard-code /usr/bin/spanpaper{,-tray} here
    # so the units work without setup.sh.
    install -d "$pkgdir/usr/lib/systemd/user"
    sed "s|@SPANPAPER_BIN@|/usr/bin/spanpaper|g" contrib/spanpaper.service \
        > "$pkgdir/usr/lib/systemd/user/spanpaper.service"
    chmod 644 "$pkgdir/usr/lib/systemd/user/spanpaper.service"

    # Ship the XDG autostart .desktops as samples, NOT in /etc/xdg/autostart,
    # because installing them there would silently autostart for every user
    # of the box. Users who want autostart copy them into ~/.config/autostart/.
    install -d "$pkgdir/usr/share/spanpaper/autostart"
    sed "s|@SPANPAPER_BIN@|/usr/bin/spanpaper|g" contrib/spanpaper.desktop \
        > "$pkgdir/usr/share/spanpaper/autostart/spanpaper.desktop"
    chmod 644 "$pkgdir/usr/share/spanpaper/autostart/spanpaper.desktop"
    sed "s|@SPANPAPER_TRAY_BIN@|/usr/bin/spanpaper-tray|g" contrib/spanpaper-tray.desktop \
        > "$pkgdir/usr/share/spanpaper/autostart/spanpaper-tray.desktop"
    chmod 644 "$pkgdir/usr/share/spanpaper/autostart/spanpaper-tray.desktop"

    # "Open With" entries for file-manager right-click → set as span/side.
    # These land in /usr/share/applications/ (NOT NoDisplay-skipped from MIME
    # association) so every user on the box can right-click an image or video
    # and pick "Open With → Set as spanpaper span / side".
    install -d "$pkgdir/usr/share/applications"
    for slot in span side; do
        sed "s|@SPANPAPER_BIN@|/usr/bin/spanpaper|g" \
            "contrib/spanpaper-set-$slot.desktop" \
            > "$pkgdir/usr/share/applications/spanpaper-set-$slot.desktop"
        chmod 644 "$pkgdir/usr/share/applications/spanpaper-set-$slot.desktop"
    done

    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm644 LICENSE   "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
