# Maintainer: Ian McMurray <ian.mcmurray@gmail.com>
#
# Binary pacman package for spanpaper. Pulls the prebuilt x86_64 tarball
# from the GitHub release — installs in seconds, no Rust toolchain
# required. This is the PKGBUILD used to produce the .pkg.tar.zst
# attached to each GitHub release.
#
# Build the .pkg.tar.zst from here:
#   cp PKGBUILD-bin /tmp/build/PKGBUILD && cd /tmp/build && makepkg
#
# Install on a fresh machine without building anything:
#   curl -LO https://github.com/imcmurray/spanpaper/releases/download/v0.2.0/spanpaper-bin-0.2.0-1-x86_64.pkg.tar.zst
#   sudo pacman -U spanpaper-bin-0.2.0-1-x86_64.pkg.tar.zst
#
# Cutting a new version:
#   1. Upload the new binary tarball to the GitHub release.
#   2. Bump pkgver, reset pkgrel=1.
#   3. Run `updpkgsums` (copy this file to PKGBUILD first — updpkgsums
#      doesn't take a -p flag).
#   4. Rebuild this .pkg.tar.zst and upload it to the release.

pkgname=spanpaper-bin
_pkgname=spanpaper
pkgver=0.3.1
pkgrel=1
pkgdesc="Wayland wallpaper daemon + tray applet — single image or video spanned across stacked monitors (prebuilt binary)"
arch=('x86_64')
url="https://github.com/imcmurray/spanpaper"
license=('MIT')
# mpvpaper + swaybg drive the wallpaper rendering. gtk4 and
# gtk4-layer-shell are linked by the optional tray applet; the daemon
# alone doesn't need them, but since 0.3.0 ships both binaries we make
# the deps unconditional so a fresh `pacman -U` install just works.
depends=('mpvpaper' 'swaybg' 'gtk4' 'gtk4-layer-shell')
provides=("$_pkgname=$pkgver")
conflicts=("$_pkgname")
source=("$_pkgname-$pkgver-x86_64.tar.gz::$url/releases/download/v$pkgver/$_pkgname-$pkgver-x86_64.tar.gz")
sha256sums=('c1883a2fb014374dc5bab9e5b61e64f74514111a4f8c8aec1026b525f2b257d8')

package() {
    cd "$_pkgname-$pkgver-x86_64"

    install -Dm755 spanpaper      "$pkgdir/usr/bin/spanpaper"
    install -Dm755 spanpaper-tray "$pkgdir/usr/bin/spanpaper-tray"

    install -d "$pkgdir/usr/lib/systemd/user"
    sed "s|@SPANPAPER_BIN@|/usr/bin/spanpaper|g" contrib/spanpaper.service \
        > "$pkgdir/usr/lib/systemd/user/spanpaper.service"
    chmod 644 "$pkgdir/usr/lib/systemd/user/spanpaper.service"

    install -d "$pkgdir/usr/share/spanpaper/autostart"
    sed "s|@SPANPAPER_BIN@|/usr/bin/spanpaper|g" contrib/spanpaper.desktop \
        > "$pkgdir/usr/share/spanpaper/autostart/spanpaper.desktop"
    chmod 644 "$pkgdir/usr/share/spanpaper/autostart/spanpaper.desktop"

    sed "s|@SPANPAPER_TRAY_BIN@|/usr/bin/spanpaper-tray|g" contrib/spanpaper-tray.desktop \
        > "$pkgdir/usr/share/spanpaper/autostart/spanpaper-tray.desktop"
    chmod 644 "$pkgdir/usr/share/spanpaper/autostart/spanpaper-tray.desktop"

    # "Open With" entries for file-manager right-click → set as span/side.
    install -d "$pkgdir/usr/share/applications"
    for slot in span side; do
        sed "s|@SPANPAPER_BIN@|/usr/bin/spanpaper|g" \
            "contrib/spanpaper-set-$slot.desktop" \
            > "$pkgdir/usr/share/applications/spanpaper-set-$slot.desktop"
        chmod 644 "$pkgdir/usr/share/applications/spanpaper-set-$slot.desktop"
    done

    install -Dm644 README.md "$pkgdir/usr/share/doc/$_pkgname/README.md"
    install -Dm644 LICENSE   "$pkgdir/usr/share/licenses/$_pkgname/LICENSE"
}
