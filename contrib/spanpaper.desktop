[Desktop Entry]
Type=Application
Name=spanpaper
Comment=Spanning video wallpaper for Wayland
# IMPORTANT: setup.sh substitutes @SPANPAPER_BIN@ with the real path. The
# session autostart runs with PATH=/usr/local/bin:/usr/bin:/bin (no
# ~/.local/bin), so the Exec= field MUST be an absolute path.
Exec=@SPANPAPER_BIN@ start --background
Terminal=false
Categories=Utility;
X-GNOME-Autostart-enabled=true
NoDisplay=true
